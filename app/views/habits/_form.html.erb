<%= form_with model: habit, class: "space-y-4" do |f| %>
  <% if habit.errors.any? %>
    <div class="alert alert-error">
      <ul>
        <% habit.errors.full_messages.each do |message| %>
          <li class="text-sm"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "習慣タイトル", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.text_field :title, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= f.label :content, "習慣内容", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.text_area :content, rows: 4, class: "textarea textarea-bordered w-full" %>
  </div>

  <div>
    <%= f.label :minimum_goal, "最低目標", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.text_field :minimum_goal, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= f.label :exception_rule, "習慣ルール", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.text_field :exception_rule, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= f.label :goal_days, "目標期間", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.select :goal_days,
        Habit::GOAL_DAYS_OPTIONS,
        { include_blank: false },
        class: "select select-bordered w-full" %>
  </div>

  <div>
    <%= f.label :status, "ステータス", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.select :status,
        Habit.statuses.keys.map { |s| [I18n.t("enums.habit.status.#{s}"), s] },
        {},
        class: "select select-bordered w-full" %>
  </div>

  <%= f.submit habit.new_record? ? "登録" : "更新", class: "btn btn-primary w-full mt-2" %>
<% end %>
