<%= form_with model: [@habit, habit_check], class: "space-y-4" do |f| %>
  <% if habit_check.errors.any? %>
    <div class="alert alert-error">
      <ul>
        <% habit_check.errors.full_messages.each do |message| %>
          <li class="text-sm"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card bg-base-100 border border-base-200">
    <div class="card-body p-4 space-y-3">
      <p class="text-sm text-base-content/70">習慣の評価</p>
      <label class="flex items-center gap-3 cursor-pointer">
        <%= f.radio_button :evaluation, :all_achieved, class: "radio radio-primary" %>
        <span class="text-sm">全ての習慣を達成</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <%= f.radio_button :evaluation, :minimum_achieved, class: "radio radio-info" %>
        <span class="text-sm">最低目標を達成</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <%= f.radio_button :evaluation, :exception, class: "radio radio-warning" %>
        <span class="text-sm">例外で未達成</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <%= f.radio_button :evaluation, :room_for_growth, class: "radio" %>
        <span class="text-sm">伸びしろあり</span>
      </label>
    </div>
  </div>

  <div>
    <%= f.label :exception_content, "例外内容", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.text_field :exception_content, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= f.label :exception_condition, "例外条件", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.text_field :exception_condition, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= f.label :memo, "メモ", class: "text-sm text-base-content/70 block mb-1" %>
    <%= f.text_area :memo, rows: 3, class: "textarea textarea-bordered w-full" %>
  </div>

  <%= f.hidden_field :checked_on, value: habit_check.checked_on %>
  <% if params[:from] %>
    <%= hidden_field_tag :from, params[:from] %>
  <% end %>
  <%= f.submit habit_check.new_record? ? "登録" : "更新", class: "btn btn-primary w-full" %>
<% end %>
