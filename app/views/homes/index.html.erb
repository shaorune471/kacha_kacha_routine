<% content_for :header do %>
  <nav class="navbar bg-base-100 border-b border-base-200">
    <div class="max-w-xl mx-auto w-full flex justify-center">
      <span class="text-lg font-medium">ホーム</span>
    </div>
  </nav>
<% end %>

<div class="px-6 py-8 bg-base-200 min-h-screen">
  <div class="max-w-xl mx-auto">

    <%# リフレーミングバナー %>
    <% if @show_reframing_banner %>
      <%= link_to reframing_path, class: "block mb-6" do %>
        <div class="alert bg-info/10 border border-info/30">
          <p class="text-sm text-info">完璧主義のリフレーミングをしませんか？</p>
        </div>
      <% end %>
    <% end %>

    <%# 経験値・進捗 %>
    <div class="grid grid-cols-2 gap-3 mb-6">
      <div class="bg-base-100 rounded-xl p-4 border border-base-200">
        <p class="text-xs text-base-content/60 mb-1">経験値</p>
        <p class="text-xl font-medium"><%= @total_experience %> pt</p>
      </div>
      <div class="bg-base-100 rounded-xl p-4 border border-base-200">
        <p class="text-xs text-base-content/60 mb-1">今日の進捗</p>
        <p class="text-xl font-medium"><%= @checked_today_count %> / <%= @all_habits.count %></p>
      </div>
    </div>

    <%# 習慣一覧 %>
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-medium">習慣一覧</h2>
      <%= link_to "習慣を登録", new_habit_path, class: "btn btn-primary btn-sm" %>
    </div>

    <%# ステータスフィルター %>
    <div class="flex gap-2 mb-3">
      <% [["active", "継続中"], ["paused", "休止中"], ["completed", "完了"]].each do |status, label| %>
        <%
          selected = @selected_statuses.include?(status)
          new_statuses = selected ? @selected_statuses - [status] : @selected_statuses + [status]
          new_statuses = ["active"] if new_statuses.empty?
        %>
        <%= link_to label, home_path(status: new_statuses, q: params[:q]&.to_unsafe_h), class: "btn btn-sm #{selected ? 'btn-primary' : 'btn-outline'}" %>
      <% end %>
    </div>

    <%= search_form_for @q, url: home_path, method: :get, class: "mb-4" do |f| %>
      <div data-controller="autocomplete"
          data-autocomplete-url-value="<%= autocomplete_home_path %>">
        <div class="flex gap-2">
          <%= f.search_field :title_or_content_cont,
              placeholder: "習慣タイトルや内容で検索",
              class: "input input-bordered flex-1 input-sm",
              data: { autocomplete_target: "input" } %>
          <%= f.submit "検索", class: "btn btn-outline btn-sm" %>
        </div>
        <ul data-autocomplete-target="results"
            class="bg-base-100 border border-base-200 rounded-lg mt-1"></ul>
      </div>
      <% @selected_statuses.each do |status| %>
        <%= hidden_field_tag "status[]", status %>
      <% end %>
    <% end %>

    <% if @habits.empty? %>
      <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-6 text-center">
          <p class="text-sm text-base-content/60">習慣がまだ登録されていません。</p>
          <%= link_to "最初の習慣を登録する", new_habit_path, class: "btn btn-primary btn-sm mt-3" %>
        </div>
      </div>
    <% else %>
      <% @habits.each do |habit| %>
        <div class="card bg-base-100 border border-base-200 mb-3">
          <div class="card-body p-0">

            <%= link_to habit_path(habit), class: "block p-4" do %>
              <div class="flex items-center justify-between mb-1">
                <p class="text-sm font-medium"><%= habit.title %></p>
                <span class="text-xs text-base-content/60">習慣ポイント：<%= habit.total_points %></span>
              </div>
              <p class="text-xs text-base-content/60">最低目標：<%= habit.minimum_goal %></p>
              <% if habit.goal_days.present? %>
                <div class="mt-2">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-base-content/60">目標期間：<%= habit.total_points %>/<%= habit.goal_days %>日達成</span>
                    <span class="text-xs text-base-content/60"><%= habit.goal_progress_percentage %>%</span>
                  </div>
                  <div class="w-full bg-base-200 rounded-full h-1.5">
                    <div class="bg-primary h-1.5 rounded-full" style="width: <%= habit.goal_progress_percentage %>%"></div>
                  </div>
                </div>
              <% end %>
            <% end %>

            <% if habit.checked_today? %>
              <%= link_to edit_habit_habit_check_path(habit, habit.habit_checks.find_by(checked_on: Date.today)), class: "flex items-center justify-between px-4 py-2 bg-base-200/50 hover:bg-base-200" do %>
                <span class="text-xs text-base-content/60">習慣チェック：<%= habit.title %></span>
                <span class="badge badge-primary badge-sm">チェック済み</span>
              <% end %>
            <% else %>
              <%= link_to new_habit_habit_check_path(habit), class: "flex items-center justify-between px-4 py-2 bg-base-200/50 hover:bg-base-200" do %>
                <span class="text-xs text-base-content/60">習慣チェック：<%= habit.title %></span>
                <span class="badge badge-ghost badge-sm">未チェック</span>
              <% end %>
            <% end %>

          </div>
        </div>
      <% end %>
    <% end %>

  </div>
</div>
