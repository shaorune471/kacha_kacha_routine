<div class="px-6 py-10 min-h-screen bg-base-200">
  <div class="max-w-sm mx-auto">
    <div class="card bg-base-100 border border-base-200">
      <div class="card-body p-6">
        <h1 class="text-lg font-medium mb-6">ログイン</h1>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="mb-4">
            <%= f.label :email, "メールアドレス", class: "text-sm text-base-content/70 block mb-1" %>
            <%= f.email_field :email, autofocus: true, class: "input input-bordered w-full" %>
          </div>

          <div class="mb-6">
            <%= f.label :password, "パスワード", class: "text-sm text-base-content/70 block mb-1" %>
            <%= f.password_field :password, class: "input input-bordered w-full" %>
          </div>

          <%= f.submit "ログイン", class: "btn btn-primary w-full" %>
        <% end %>

        <div class="divider">または</div>
        <form action="/users/auth/google_oauth2" method="post" data-turbo="false">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="btn btn-outline w-full">Googleでログイン</button>
        </form>

        <div class="text-center mt-4">
          <p class="text-sm text-base-content/70">
            アカウントをお持ちでない方は
            <%= link_to "新規登録", new_registration_path(resource_name), class: "text-primary" %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
