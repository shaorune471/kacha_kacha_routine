<% content_for :header do %>
  <nav class="navbar bg-base-100 border-b border-base-200">
    <div class="max-w-xl mx-auto w-full flex justify-center">
      <span class="text-lg font-medium">設定</span>
    </div>
  </nav>
<% end %>

<div class="px-6 py-8 bg-base-200 min-h-screen">
  <div class="max-w-xl mx-auto space-y-4">

    <%= form_with model: current_user, url: settings_path, method: :patch do |f| %>

      <% if current_user.errors.any? %>
        <div class="alert alert-error">
          <ul>
            <% current_user.errors.full_messages.each do |message| %>
              <li class="text-sm"><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# プロフィール %>
      <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-5">
          <p class="text-sm font-medium mb-3">プロフィール</p>
          <div class="space-y-3">
            <div>
              <%= f.label :name, "名前", class: "text-sm text-base-content/70 block mb-1" %>
              <%= f.text_field :name, class: "input input-bordered w-full" %>
            </div>
            <div>
              <%= f.label :email, "メールアドレス", class: "text-sm text-base-content/70 block mb-1" %>
              <%= f.email_field :email, class: "input input-bordered w-full" %>
            </div>
          </div>
        </div>
      </div>

      <%# パスワード変更 %>
      <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-5">
          <p class="text-sm font-medium mb-3">パスワード変更</p>
          <div class="space-y-3">
            <div>
              <%= f.label :current_password, "現在のパスワード", class: "text-sm text-base-content/70 block mb-1" %>
              <%= f.password_field :current_password, class: "input input-bordered w-full", autocomplete: "current-password" %>
            </div>
            <div>
              <%= f.label :password, "新しいパスワード", class: "text-sm text-base-content/70 block mb-1" %>
              <%= f.password_field :password, class: "input input-bordered w-full", autocomplete: "new-password" %>
            </div>
            <div>
              <%= f.label :password_confirmation, "新しいパスワード確認", class: "text-sm text-base-content/70 block mb-1" %>
              <%= f.password_field :password_confirmation, class: "input input-bordered w-full", autocomplete: "new-password" %>
            </div>
          </div>
        </div>
      </div>

      <%# 習慣数の上限 %>
      <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-5">
          <p class="text-sm font-medium mb-3">習慣数の上限</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-base-content/70">上限あり（<%= Habit::HABIT_LIMIT %>個まで）</p>
              <p class="text-xs text-base-content/50">完璧主義者は習慣を詰め込みすぎる傾向があります</p>
            </div>
            <%= f.check_box :habit_limit, class: "toggle toggle-primary", checked: current_user.habit_limit? %>
          </div>
        </div>
      </div>

      <%# 通知設定 %>
      <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-5">
          <p class="text-sm font-medium mb-3">通知設定</p>
          <div class="flex items-center justify-between mb-4">
            <div>
              <p class="text-sm text-base-content/70">再開サポートメール</p>
              <p class="text-xs text-base-content/50">2週間チェックがない場合にメールを送信します</p>
            </div>
            <%= f.check_box :reengagement_notification, class: "toggle toggle-primary", checked: current_user.reengagement_notification? %>
          </div>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-base-content/70">習慣リマインダーメール</p>
              <p class="text-xs text-base-content/50">毎日22時に未チェックの習慣をお知らせします</p>
            </div>
            <%= f.check_box :reminder_notification, class: "toggle toggle-primary", checked: current_user.reminder_notification? %>
          </div>
        </div>
      </div>

      <%# 振り返り開始曜日 %>
      <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-5">
          <p class="text-sm font-medium mb-3">振り返りの開始曜日</p>
          <div class="flex items-center gap-3">
            <%= f.select :review_start_day,
                User::DAYS_OF_WEEK.map { |k, v| [v, k] },
                {},
                class: "select select-bordered w-full" %>
          </div>
          <p class="text-xs text-base-content/50 mt-2">週の集計をどの曜日から始めるか設定します</p>
        </div>
      </div>

      <%# ダークモード %>
      <div class="card bg-base-100 border border-base-200">
        <div class="card-body p-5">
          <p class="text-sm font-medium mb-3">表示設定</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-base-content/70">ダークモード</p>
              <p class="text-xs text-base-content/50">画面を暗いテーマに切り替えます</p>
            </div>
            <%= f.check_box :dark_mode, class: "toggle toggle-primary", checked: current_user.dark_mode? %>
          </div>
        </div>
      </div>

      <%= f.submit "設定を保存", class: "btn btn-primary w-full" %>

    <% end %>

    <%# ログアウト %>
    <div class="card bg-base-100 border border-base-200">
      <div class="card-body p-5">
        <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "btn btn-outline w-full" %>
      </div>
    </div>

  </div>
</div>
