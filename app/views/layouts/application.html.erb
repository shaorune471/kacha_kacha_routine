<!DOCTYPE html>
<html data-theme="<%= user_signed_in? && current_user.dark_mode? ? "dark" : "emerald" %>">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "HabitResteps" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= display_meta_tags(
      site: "HabitResteps",
      title: "HabitResteps（ハビットリステップ）",
      description: "完璧主義でも続けられる習慣アプリ。習慣が途切れても大丈夫。踏み出そう、何度でも。",
      og: {
        title: :title,
        description: :description,
        type: "website",
        url: "https://habit-resteps.onrender.com",
        image: image_url("ogp.png")
      },
      twitter: {
        card: "summary_large_image",
        title: :title,
        description: :description,
        image: image_url("ogp.png")
      }
    ) %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex flex-col"
        data-controller="theme"
        data-current-theme="<%= user_signed_in? && current_user.dark_mode? ? "dark" : "emerald" %>">
    <% if content_for?(:header) %>
      <%= yield :header %>
    <% else %>
      <%= render "shared/header" %>
    <% end %>
    <main class="flex-1">
      <% if notice %>
        <div class="max-w-xl mx-auto px-6 pt-4">
          <div class="alert alert-success text-sm"><%= notice %></div>
        </div>
      <% end %>
      <% if alert %>
        <div class="max-w-xl mx-auto px-6 pt-4">
          <div class="alert alert-error text-sm"><%= alert %></div>
        </div>
      <% end %>
      <%= yield %>
    </main>
    <% if user_signed_in? && !session[:onboarding] %>
      <%= render "shared/footer" %>
    <% end %>
  </body>
</html>
